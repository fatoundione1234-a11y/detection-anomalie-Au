# ============================================================
# GeoSat Kédougou — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos clés API
# NE JAMAIS COMMITER LE FICHIER .env
# ============================================================

# ── SENTINEL-2 (Copernicus Open Access Hub) ─────────────────
SENTINEL_USER=votre_email@example.com
SENTINEL_PASSWORD=votre_mot_de_passe

# ── LANDSAT-9 (USGS EarthExplorer) ──────────────────────────
USGS_USERNAME=votre_username_usgs
USGS_PASSWORD=votre_mot_de_passe_usgs

# ── SENTINEL HUB (optionnel — accès rapide API) ─────────────
SENTINEL_HUB_CLIENT_ID=votre_client_id
SENTINEL_HUB_CLIENT_SECRET=votre_client_secret

# ── MAPBOX (optionnel — tuiles personnalisées) ───────────────
MAPBOX_TOKEN=pk.eyJ1IjoivotreProfil...

# ── GOOGLE EARTH ENGINE (optionnel) ─────────────────────────
GEE_PROJECT=votre_projet_gee
GEE_SERVICE_ACCOUNT=votre_service_account@gee.iam.gserviceaccount.com
GEE_KEY_FILE=path/to/gee_key.json

# ── APPLICATION ──────────────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
